# ===== 情绪爆破局环境变量样例 =====
# 使用前复制为 .env 并填入真实值：cp .env.example .env

# 服务端口
PORT=3000
NODE_ENV=development

# WebSocket CORS 允许来源（生产环境请配置具体前端域名，如 https://example.com；留空则降级为 * 允许所有来源）
CORS_ORIGIN=

# JWT 签名密钥（必填，生产环境请使用强随机串）
JWT_SECRET=

# PostgreSQL 数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_USER=emotion
DB_PASSWORD=
DB_NAME=emotion_burst

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
# Redis 密码（无密码可留空）
REDIS_PASSWORD=
# Redis 数据库编号（共享实例时区分项目，默认 1）
REDIS_DB=1

# AI 服务配置（必填）
AI_API_KEY=
AI_API_URL=
